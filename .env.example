# Google OAuth 2.0 Credentials
# Lấy từ: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET

# URL backend sẽ nhận callback từ Google (phải khớp với Authorized redirect URIs trên GCC)
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# Session secret — chuỗi ngẫu nhiên dài, dùng để ký session (tạo bằng: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# Thời gian session tồn tại (giây). Mặc định: 7 ngày
SESSION_TTL_SECONDS=604800

# Thời gian cache Google Sheets (giây). Mặc định: 5 phút
SHEETS_CACHE_TTL_SECONDS=300

# Server
HOST=0.0.0.0
PORT=8080
FRONTEND_DIR=frontend

# Supabase — SDK Version Management
# Lấy từ: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Ngưỡng alert adoption rate (%)
ADOPTION_WARN_THRESHOLD=80
ADOPTION_CRITICAL_THRESHOLD=50
