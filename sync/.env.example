# MCP API
MCP_BASE_URL=https://mcp-gateway.gio.vng.vn/mcp

# MCP OAuth 2.0 Client Credentials
# POST {MCP_OAUTH_TOKEN_URL} với grant_type=client_credentials → access_token valid 1h
MCP_OAUTH_TOKEN_URL=https://mcp-gateway.gio.vng.vn/token
MCP_OAUTH_CLIENT_ID=your_client_id
MCP_OAUTH_CLIENT_SECRET=your_client_secret

# Supabase (dùng service role key — không phải anon key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Platforms cần lấy (comma-separated)
PLATFORMS=android,ios,windows

# Ngưỡng alert (%)
ADOPTION_WARN_THRESHOLD=80
ADOPTION_CRITICAL_THRESHOLD=50
