# MCP API
MCP_BASE_URL=https://your-mcp-host/api
MCP_BEARER_TOKEN=your_bearer_token_here

# Supabase (dùng service role key — không phải anon key)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Platforms cần lấy (comma-separated)
PLATFORMS=android,ios,windows

# Ngưỡng alert (%)
ADOPTION_WARN_THRESHOLD=80
ADOPTION_CRITICAL_THRESHOLD=50
